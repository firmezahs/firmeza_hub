<!-- views/partials/sidebar.ejs -->
<!-- Replace your existing sidebar partial with this -->

<div class="sidebar-new">
  <h2>Firmeza</h2>

  <a href="/dashboard" class="<%= activePage === 'dashboard' ? 'active' : '' %>">
    <i class="ri-home-4-fill"></i> Dashboard
  </a>

  <a href="/clients" class="<%= activePage === 'clients' ? 'active' : '' %>">
    <i class="ri-user-fill"></i> Clients
  </a>

  <!-- Admin-only links -->
  <% if (user && user.role === 'admin') { %>

    <a href="/developers" class="<%= activePage === 'developers' ? 'active' : '' %>">
      <i class="ri-team-line"></i> Developers
    </a>

    <a href="/services" class="<%= activePage === 'services' ? 'active' : '' %>">
      <i class="ri-customer-service-2-line"></i> Services
    </a>

  <% } %>

  <a href="/auth/logout">
    <i class="ri-logout-box-r-line"></i> Logout
  </a>
</div>
