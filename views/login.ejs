<!DOCTYPE html>
<html>
<head>
  <title>Login | Firmeza Hub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="login-page">

    <div class="login-container">

      <!-- LEFT SIDE -->
      <div class="login-left">
        <h1>Welcome</h1>
        <p>
          Manage your agreements, clients and documents in one place.
          Secure, fast and easy to use platform.
        </p>
      </div>

      <!-- RIGHT SIDE -->
      <div class="login-right">

        <div class="brand">Firmeza Hub</div>

        <form action="/auth/login" method="POST">

          <div class="form-group">
            <label>Email</label>
            <input 
              type="email" 
              name="email" 
              placeholder="Enter your email"
              value="admin@firmeza.com"
              required 
            />
          </div>

          <div class="form-group">
            <label>Password</label>
            <input 
              type="password" 
              name="password" 
              placeholder="Enter your password"
              value="123456"
              required 
            />
          </div>

          <button type="submit">Login</button>

        </form>

      </div>

    </div>

  </div>

</body>
</html>