<!DOCTYPE html>
<html>

<head>
    <title><%= project ? 'Edit Project' : 'Add Project' %></title>
    <link rel="stylesheet" href="/css/style.css">

    <style>
        .confirm-modal {
            display: none;
        }

        .confirm-modal.show {
            display: flex;
        }
    </style>
</head>

<body>

<div class="admin-container">

    <%- include('../../partials/sidebar', { activePage: 'clients' }) %>

    <div class="main-new">
        <%- include('../../partials/header') %>

        <div class="content-area">

            <!-- BREADCRUMB -->
            <div class="breadcrumb">
                <a href="/dashboard">Dashboard</a>
                <span> / </span>
                <a href="/clients">Clients</a>
                <span> / </span>
                <a href="/clients/view-page/<%= client._id %>?tab=projects">Projects</a>
                <span> / </span>
                <span class="active"><%= project ? 'Edit Project' : 'Add Project' %></span>
            </div>

            <h2 style="margin-bottom:15px;">
                <%= project ? 'Edit Project' : 'Add Project' %>
            </h2>

            <div class="form-card">

                <!-- ✅ SAFE: store state in HTML attribute -->
                <form id="projectForm"
                      data-is-update="<%= project ? '1' : '0' %>"
                      action="<%= project ? '/clients/projects/edit/' + project._id : '/clients/projects/add/' + client._id %>"
                      method="POST">

                    <div class="form-grid" style="grid-template-columns: 1fr;">

                        <div class="form-group">
                            <label>Title <span class="required">*</span></label>
                            <input type="text" name="title" required
                                value="<%= project ? project.title : '' %>">
                        </div>

                        <div class="form-group">
                            <label>Description</label>
                            <textarea name="description" rows="5"><%= project && project.description ? project.description : '' %></textarea>
                        </div>

                        <div class="form-group">
                            <label>Developer</label>
                            <input type="text" name="developer"
                                value="<%= (project && project.developer && project.developer !== 'Not Assigned') ? project.developer : '' %>">
                        </div>

                    </div>

                    <div class="form-actions">

                        <button type="button" class="cancel-btn"
                            onclick="window.location.href='/clients/view-page/<%= client._id %>?tab=projects'">
                            Cancel
                        </button>

                        <button type="submit" class="save-btn">
                            <%= project ? 'Update Project' : 'Save Project' %>
                        </button>

                    </div>

                </form>

            </div>

        </div>
    </div>

</div>

<!-- MODAL -->
<div id="confirmModal" class="confirm-modal <%= project ? 'update-modal' : '' %>">
    <div class="confirm-box">

        <div class="confirm-header">
            <h3 id="modalTitle">Confirm</h3>
            <span class="modal-close" id="closeModal">&times;</span>
        </div>

        <div class="confirm-body" id="modalMessage"></div>

        <div class="confirm-actions">
            <button id="cancelModal">Cancel</button>
            <button id="confirmModalBtn">Confirm</button>
        </div>

    </div>
</div>

<!-- SCRIPT -->
<script>
const form = document.getElementById("projectForm");
const modal = document.getElementById("confirmModal");
const title = document.getElementById("modalTitle");
const message = document.getElementById("modalMessage");

const cancelBtn = document.getElementById("cancelModal");
const closeBtn = document.getElementById("closeModal");
const confirmBtn = document.getElementById("confirmModalBtn");

let isSubmitting = false;

// READ SAFE VALUE FROM HTML
const isUpdate = form.dataset.isUpdate === "1";

// OPEN MODAL
function openModal(type, text, onConfirm) {
    title.innerText = type;
    message.innerText = text;

    // RESET ALL STYLES
    const box = modal.querySelector(".confirm-box");
    box.style.borderLeft = "";
    title.style.color = "";
    confirmBtn.style.background = "";

    // APPLY BASED ON TYPE
    if (type.includes("Update")) {
        // 🟠 ORANGE
        box.style.borderLeft = "6px solid #f59e0b";
        title.style.color = "#f59e0b";
        confirmBtn.style.background = "#f59e0b";
    } else {
        // 🔵 BLUE (SAVE)
        box.style.borderLeft = "6px solid #3b82f6";
        title.style.color = "#3b82f6";
        confirmBtn.style.background = "#3b82f6";
    }

    modal.classList.add("show");

    confirmBtn.onclick = function () {
        if (isSubmitting) return;
        isSubmitting = true;
        modal.classList.remove("show");
        onConfirm();
    };
}

// CLOSE MODAL
function closeModal() {
    modal.classList.remove("show");
}

cancelBtn.onclick = closeModal;
closeBtn.onclick = closeModal;

// SUBMIT
form.addEventListener("submit", function (e) {
    e.preventDefault();

    openModal(
        isUpdate ? "Confirm Update" : "Confirm Save",
        isUpdate
            ? "Do you really want to update this project?"
            : "Do you really want to save this project?",
        () => form.submit()
    );
});
</script>

</body>
</html>