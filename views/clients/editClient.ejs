<!DOCTYPE html>
<html>

<head>
    <title>Edit Client | Firmeza Hub</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@18.1.1/build/css/intlTelInput.css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
</head>

<body>

    <input type="hidden" id="emailExistsValue" value="<%= emailExists || false %>">

    <div class="admin-container">

        <%- include('../partials/sidebar', { activePage: activePage }) %>

        <div class="main-new">

            <%- include('../partials/header') %>

            <div class="content-area">

                <p class="breadcrumb">
                    <a href="/dashboard">Dashboard</a> /
                    <a href="/clients">Clients</a> /
                    <span class="dark">Edit Client</span>
                </p>

                <div class="page-header-new">
                    <h1>Edit Client</h1>
                </div>

                <div class="form-card">

                    <form id="clientForm" action="/clients/edit/<%= client._id %>" method="POST"
                        enctype="multipart/form-data" class="client-form">

                        <div class="form-group">
                            <label>Name <span class="required">*</span></label>
                            <input type="text" id="name" name="name" value="<%= client.name %>">
                        </div>

                        <div class="form-group">
                            <label>Company Name <span class="required">*</span></label>
                            <input type="text" id="companyName" name="companyName"
                                value="<%= client.companyName %>">
                        </div>

                        <!-- COUNTRY -->
                        <div class="form-group">
                            <label>Country</label>

                            <div class="custom-select">
                                <div class="select-box" id="selectBox">
                                    <span id="selectedText">Select Country</span>
                                    <i class="ri-arrow-down-s-line"></i>
                                </div>

                                <div class="select-dropdown" id="dropdown">
                                    <input type="text" id="searchCountry" placeholder="Search country...">

                                    <div class="options">
                                        <% countries.forEach(c=> { %>
                                            <div class="option"
                                                data-name="<%= c.name %>"
                                                data-iso="<%= c.iso2 %>">
                                                <%= c.name %>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>

                                <input type="hidden" name="country" id="countryValue"
                                    value="<%= client.country || '' %>">
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Mobile Number <span class="required">*</span></label>
                            <input type="text" id="mobileNumber" name="mobileNumber"
                                value="<%= client.mobileNumber %>">
                        </div>

                        <div class="form-group">
                            <label>Email <span class="required">*</span></label>

                            <input type="text" id="email" name="email"
                                value="<%= client.email %>"
                                class="<%= emailExists ? 'input-error' : '' %>">

                            <small class="error-message <%= emailExists ? 'show-error' : '' %>">
                                <%= emailExists ? 'Email already exists' : '' %>
                            </small>
                        </div>

                        <div class="form-group">
                            <label>GST Number</label>
                            <input type="text" name="gstNumber" value="<%= client.gstNumber || '' %>">
                        </div>

                        <div class="form-group">
                            <label>Address</label>
                            <textarea id="address" name="address"><%= client.address || '' %></textarea>
                        </div>

                        <div class="form-group">
                            <label>Logo</label>

                            <div class="logo-upload-wrapper">
                                <div class="logo-preview" id="logoPreview">
                                    <% if (client.logo) { %>
                                        <img src="/uploads/<%= client.logo %>" />
                                        <span class="remove-logo" onclick="removeLogo()">×</span>
                                    <% } %>
                                </div>

                                <input type="file" name="logo" id="logoInput">
                                <input type="hidden" name="removeLogo" id="removeLogoInput" value="false">
                            </div>
                        </div>

                        <div class="form-actions">
                            <a href="/clients" class="cancel-btn">Cancel</a>
                            <button type="button" id="submitBtn" class="save-btn">Update Client</button>
                        </div>

                    </form>

                </div>

            </div>
        </div>
    </div>

    <!-- MODAL -->
    <div id="editModal" class="modal">
        <div class="modal-content modern warning">
            <div class="modal-header">
                <h3>Confirm</h3>
                <span class="close-btn" onclick="closeEditModal()">&times;</span>
            </div>

            <p>Do you really want to update this client?</p>

            <div class="modal-actions">
                <button onclick="closeEditModal()">Cancel</button>
                <button class="update-btn" onclick="confirmEdit()">Confirm</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@18.1.1/build/js/intlTelInput.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@18.1.1/build/js/utils.js"></script>

    <script>
        const input = document.querySelector("#mobileNumber");

        const iti = window.intlTelInput(input, {
            separateDialCode: true,
            initialCountry: "auto",
            preferredCountries: ["in", "us", "gb"],
            utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@18.1.1/build/js/utils.js"
        });

        // IMPORTANT: set existing number properly
        window.addEventListener("load", () => {
            if (input.value) {
                iti.setNumber(input.value);
            }
        });

        function confirmEdit() {
            input.value = iti.getNumber();
            document.getElementById("clientForm").submit();
        }

        // ---------------- COUNTRY DROPDOWN FIX ----------------
        const selectBox = document.getElementById("selectBox");
        const dropdown = document.getElementById("dropdown");
        const searchInput = document.getElementById("searchCountry");
        const options = document.querySelectorAll(".option");
        const selectedText = document.getElementById("selectedText");
        const hiddenInput = document.getElementById("countryValue");

        selectBox.addEventListener("click", () => {
            dropdown.style.display = dropdown.style.display === "block" ? "none" : "block";
        });

        options.forEach(option => {
            option.addEventListener("click", function () {

                const name = this.dataset.name;
                const iso = this.dataset.iso;

                selectedText.textContent = name;
                hiddenInput.value = name;

                dropdown.style.display = "none";

                if (iso) {
                    iti.setCountry(iso);
                }
            });
        });

        searchInput.addEventListener("input", function () {
            const filter = this.value.toLowerCase();

            options.forEach(option => {
                option.style.display =
                    option.textContent.toLowerCase().includes(filter)
                        ? "block"
                        : "none";
            });
        });

        document.addEventListener("click", function (e) {
            if (!e.target.closest(".custom-select")) {
                dropdown.style.display = "none";
            }
        });

        // 🔥 SET COUNTRY ON LOAD (FIXED)
        window.addEventListener("load", function () {
            const existing = hiddenInput.value;

            const match = Array.from(options).find(opt =>
                opt.dataset.name === existing
            );

            if (match && match.dataset.iso) {
                iti.setCountry(match.dataset.iso);
                selectedText.textContent = existing;
            }
        });

        // sync back from phone
        input.addEventListener("countrychange", function () {
            const c = iti.getSelectedCountryData();
            hiddenInput.value = c.name;
            selectedText.textContent = c.name;
        });

    </script>
    <script>
  document.getElementById("submitBtn").addEventListener("click", function () {
    document.getElementById("editModal").style.display = "flex";
  });

  function closeEditModal() {
    document.getElementById("editModal").style.display = "none";
  }
</script>

</body>

</html>