<!DOCTYPE html>
<html>

<head>
  <title><%= isEdit ? "Edit Credential" : "Add Credential" %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

  <style>
    .breadcrumb { margin-bottom: 20px; font-size: 14px; }
    .breadcrumb a { color: #9ca3af; text-decoration: none; }
    .breadcrumb span { color: #9ca3af; }
    .breadcrumb .active { color: #111827; font-weight: 500; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }

    .form-group { display: flex; flex-direction: column; }

    input, textarea {
      padding: 10px;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      font-size: 14px;
    }

    textarea { resize: vertical; }

    .req { color: red; margin-left: 2px; }

    .error-message {
      color: #ef4444;
      font-size: 12px;
      margin-top: 4px;
      display: none;
    }

    .input-error { border: 1px solid #ef4444 !important; }

    .switch {
      position: relative;
      display: inline-block;
      width: 44px;
      height: 24px;
    }

    .switch input { opacity: 0; width: 0; height: 0; }

    .slider {
      position: absolute;
      cursor: pointer;
      top: 0; left: 0; right: 0; bottom: 0;
      background: #ccc;
      transition: .3s;
      border-radius: 34px;
    }

    .slider:before {
      position: absolute;
      content: "";
      height: 18px;
      width: 18px;
      left: 3px;
      bottom: 3px;
      background: white;
      transition: .3s;
      border-radius: 50%;
    }

    input:checked + .slider { background: #4f46e5; }
    input:checked + .slider:before { transform: translateX(20px); }

    .switch-wrapper {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .password-wrapper { position: relative; }

    .password-wrapper i {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
      color: #6b7280;
    }

    /* ✅ ADD THIS ONLY (dynamic update color) */
    .confirm-box.update-mode {
      border-left: 6px solid #f59e0b;
    }
    .confirm-box.update-mode .confirm-header h2 {
      color: #f59e0b;
    }
    .confirm-box.update-mode .confirm-btn {
      background: #f59e0b;
    }
  </style>
</head>

<body>

<div class="admin-container">

  <%- include('../../partials/sidebar', { activePage: activePage }) %>

  <div class="main-new">

    <%- include('../../partials/header') %>

    <div class="content-area">

      <div class="breadcrumb">
        <a href="/dashboard">Dashboard</a>
        <span> / </span>

        <a href="/clients">Clients</a>
        <span> / </span>

        <a href="/clients/view-page/<%= client._id %>">Client Details</a>
        <span> / </span>

        <span class="active">
          <%= isEdit ? "Edit Credential" : "Add Credential" %>
        </span>
      </div>

      <h2 style="margin-bottom:20px;">
        <%= isEdit ? "Edit Credential" : "Add Credential" %>
      </h2>

      <div class="form-card">

        <form id="credentialForm"
              action="<%= isEdit ? '/clients/credentials/edit/' + credential._id : '/clients/credentials/add/' + client._id %>"
              method="POST">

          <div class="form-grid">

            <div class="form-group">
              <label>Title <span class="req">*</span></label>
              <input type="text" name="title" id="title"
                     value="<%= credential ? credential.title : '' %>">
              <small class="error-message" id="titleError">Title is required</small>
            </div>

            <div class="form-group">
              <label>Username <span class="req">*</span></label>
              <input type="text" name="username" id="username"
                     value="<%= credential ? credential.username : '' %>">
              <small class="error-message" id="usernameError">Username is required</small>
            </div>

            <div class="form-group">
              <label>Password <span class="req">*</span></label>

              <div class="password-wrapper">
                <input type="password" name="password" id="password"
                       value="<%= credential ? credential.password : '' %>">
                <i class="ri-eye-line" id="togglePassword"></i>
              </div>

              <small class="error-message" id="passwordError">Password is required</small>
            </div>

            <div class="form-group">
              <label>Notes</label>
              <textarea name="notes" rows="3"><%= credential ? credential.notes : '' %></textarea>
            </div>

            <div class="form-group" style="grid-column: span 2;">
              <div class="switch-wrapper">
                <label>Two Factor Authentication (2FA)</label>

                <label class="switch">
                  <input type="checkbox" name="has_2fa" value="true"
                    <%= credential && credential.has_2fa ? "checked" : "" %>>
                  <span class="slider"></span>
                </label>
              </div>
            </div>

          </div>

          <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:25px;">
            <a href="/clients/view-page/<%= client._id %>" class="cancel-btn">Cancel</a>

            <button type="button" class="save-btn" id="openConfirm">
              <%= isEdit ? "Update Credential" : "Save Credential" %>
            </button>
          </div>

        </form>

      </div>

    </div>

  </div>

</div>

<!-- ✅ CONFIRM MODAL -->
<div class="confirm-modal" id="confirmModal">
  <!-- ✅ ADD CONDITIONAL CLASS HERE -->
  <div class="confirm-box <%= isEdit ? 'update-mode' : '' %>">
    <div class="confirm-header">
      <h2>Confirm</h2>
      <span id="closeConfirm" style="cursor:pointer;">&times;</span>
    </div>

    <p class="confirm-text">
      <%= isEdit 
        ? "Do you really want to update this credential?" 
        : "Do you really want to save this credential?" %>
    </p>

    <div class="confirm-actions">
      <button type="button" class="cancel-btn" id="cancelConfirm">Cancel</button>
      <button type="button" class="confirm-btn" id="confirmSubmit">Confirm</button>
    </div>
  </div>
</div>

<script>
  const togglePassword = document.getElementById("togglePassword");
  const passwordInput = document.getElementById("password");

  togglePassword.addEventListener("click", function () {
    const isHidden = passwordInput.type === "password";
    passwordInput.type = isHidden ? "text" : "password";

    this.classList.toggle("ri-eye-line");
    this.classList.toggle("ri-eye-off-line");
  });
</script>

<script>
  const form = document.getElementById("credentialForm");

  const fields = [
    { input: document.getElementById("title"), error: document.getElementById("titleError") },
    { input: document.getElementById("username"), error: document.getElementById("usernameError") },
    { input: document.getElementById("password"), error: document.getElementById("passwordError") }
  ];

  form.addEventListener("submit", function (e) {
    let valid = true;

    fields.forEach(field => {
      if (!field.input.value.trim()) {
        field.error.style.display = "block";
        field.input.classList.add("input-error");
        valid = false;
      }
    });

    if (!valid) e.preventDefault();
  });

  fields.forEach(field => {
    field.input.addEventListener("input", function () {
      if (this.value.trim()) {
        field.error.style.display = "none";
        this.classList.remove("input-error");
      }
    });
  });
</script>

<script>
  const openBtn = document.getElementById("openConfirm");
  const modal = document.getElementById("confirmModal");
  const cancelBtn = document.getElementById("cancelConfirm");
  const closeBtn = document.getElementById("closeConfirm");
  const confirmBtn = document.getElementById("confirmSubmit");

  openBtn.addEventListener("click", function () {
    let valid = true;

    fields.forEach(field => {
      if (!field.input.value.trim()) {
        field.error.style.display = "block";
        field.input.classList.add("input-error");
        valid = false;
      }
    });

    if (valid) {
      modal.style.display = "flex";
    }
  });

  cancelBtn.onclick = () => modal.style.display = "none";
  closeBtn.onclick = () => modal.style.display = "none";

  confirmBtn.onclick = () => {
    form.submit();
  };

  window.onclick = function(e) {
    if (e.target === modal) {
      modal.style.display = "none";
    }
  };
</script>

</body>
</html>