<!DOCTYPE html>
<html>

<head>
  <title>Clients | Firmeza Hub</title>
  <link rel="stylesheet" href="/css/style.css">

  <!-- FONT -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- ICONS -->
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

  <!-- ✅ DataTables -->
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
</head>

<body>

<div class="admin-container">

  <% if (success) { %>
    <div id="toast" class="toast success">
      <i class="ri-checkbox-circle-line"></i>
      <span><%= success %></span>
    </div>
  <% } %>

  <% if (error) { %>
    <div id="toast" class="toast error">
      <i class="ri-error-warning-line"></i>
      <span><%= error %></span>
    </div>
  <% } %>

  <%- include('../partials/sidebar', { activePage: activePage }) %>

  <div class="main-new">
    <%- include('../partials/header') %>

    <div class="content-area">

      <p class="breadcrumb">
        <a href="/dashboard">Dashboard</a> /
        <a href="/clients">Clients</a>
      </p>

      <div class="page-header-new">
        <h1>
          Clients
          <span class="badge"><%= clients?.length || 0 %></span>
        </h1>
      </div>

      <div class="filter-bar">
        <div class="left-controls">
          <div class="search-box">
            <i class="ri-search-line"></i>
            <input type="text" id="customSearch" placeholder="Search...">
          </div>
        </div>

        <div class="right-controls">
          <button class="add-btn" onclick="window.location.href='/clients/add'">
            <i class="ri-add-line"></i> Add Client
          </button>

          <select id="entriesDropdown" class="entries-dropdown">
            <option value="10">10</option>
            <option value="25">25</option>
            <option value="50">50</option>
          </select>
        </div>
      </div>

      <div class="table-wrapper">
        <table id="clientsTable" class="custom-table">
          <thead>
            <tr>
              <th>Client</th>
              <th>Company</th>
              <th>Email</th>
              <th></th>
            </tr>
          </thead>

          <tbody>
            <% if (clients && clients.length > 0) { %>
              <% clients.forEach(client => { %>
                <tr>
                  <td>
                    <div class="client-main">

                      <div class="client-avatar">
                        <% if (client.logo) { %>
                          <img src="/uploads/<%= client.logo %>" class="client-logo">
                        <% } else { %>
                          <div class="client-logo placeholder">
                            <%= client.name ? client.name.charAt(0).toUpperCase() : 'A' %>
                          </div>
                        <% } %>
                      </div>

                      <div class="client-info">
                        <p class="client-code">#<%= client.clientId || '-' %></p>

                        <p class="client-name client-name-click"
                           onclick="openViewDrawer('<%= client._id %>')">
                          <%= client.name %>
                        </p>

                        <p class="client-country">
                          <%= client.country || '-' %>
                        </p>
                      </div>

                    </div>
                  </td>

                  <td><%= client.companyName %></td>
                  <td><%= client.email %></td>

                  <td class="actions">
                    <div class="dropdown">
                      <i class="ri-more-2-fill dropdown-toggle"></i>

                      <div class="dropdown-menu">
                        <div class="dropdown-item" onclick="openViewDrawer('<%= client._id %>')">
                          <i class="ri-eye-line"></i> View
                        </div>

                        <div class="dropdown-item" onclick="editClient('<%= client._id %>')">
                          <i class="ri-edit-line"></i> Edit
                        </div>

                        <div class="dropdown-item delete-text"
                             onclick="openDeleteModal('<%= client._id %>')">
                          <i class="ri-delete-bin-6-line"></i> Delete
                        </div>
                      </div>
                    </div>
                  </td>

                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>

<!-- DELETE MODAL -->
<div id="deleteModal" class="modal">
  <div class="modal-content modern">
    <div class="modal-header">
      <h3>Confirm</h3>
      <span class="close-btn" onclick="closeDeleteModal()">×</span>
    </div>

    <p>Do you really want to remove this item?</p>

    <div class="modal-actions">
      <button class="cancel-btn" onclick="closeDeleteModal()">Cancel</button>
      <button class="delete-btn" onclick="confirmDeleteAction()">Confirm</button>
    </div>
  </div>
</div>

<!-- VIEW DRAWER -->
<div id="viewDrawer" class="drawer">
  <div class="drawer-content modern-drawer">

    <div class="drawer-top">
      <button class="back-btn" onclick="closeDrawer()">
        <i class="ri-arrow-left-s-line"></i>
      </button>
      <h2>View</h2>
    </div>

    <div class="drawer-actions">
      <button class="edit-btn" onclick="goToEdit()">
        <i class="ri-edit-line"></i> Edit
      </button>

      <button class="delete-btn-outline" onclick="confirmDeleteFromDrawer()">
        <i class="ri-delete-bin-line"></i> Delete
      </button>
    </div>

    <div class="drawer-image"></div>
    <div id="drawerBody" class="drawer-body"></div>

  </div>
</div>

<!-- IMAGE PREVIEW MODAL -->
<div id="imageModal" class="image-modal">
  <span class="close-preview" onclick="closeImagePreview()">×</span>
  <img id="previewImg" class="preview-img">
</div>

<!-- SCRIPTS -->
<script>
$(document).ready(function () {
  const table = $('#clientsTable').DataTable({
    pageLength: 10,
    lengthChange: false,
    ordering: true,
    info: true,
    dom: 't<"table-footer"ip>'
  });

  $('#customSearch').on('keyup', function () {
    table.search(this.value).draw();
  });

  $('#entriesDropdown').on('change', function () {
    table.page.len(this.value).draw();
  });
});

// dropdown
$(document).on('click', '.dropdown-toggle', function (e) {
  e.stopPropagation();
  $('.dropdown-menu').hide();
  $(this).siblings('.dropdown-menu').toggle();
});

$(document).on('click', function () {
  $('.dropdown-menu').hide();
});

let selectedClientId = null;

// ✅ FIXED VIEW
function openViewDrawer(id) {
  selectedClientId = id;

  fetch(`/clients/view/${id}`)
    .then(res => res.json())
    .then(client => {

      const body = document.getElementById("drawerBody");
      const imageContainer = document.querySelector(".drawer-image");

      if (client.logo) {
        imageContainer.innerHTML = `
          <img src="/uploads/${client.logo}" 
               class="drawer-img clickable-img"
               onclick="openImagePreview('/uploads/${client.logo}')">
        `;
      } else {
        imageContainer.innerHTML = `<div class="image-placeholder"></div>`;
      }

      body.innerHTML = `
        <div class="info-block"><span>Client ID</span><p>#${client.clientId || '-'}</p></div>
        <div class="info-block"><span>Name</span><p>${client.name || '-'}</p></div>
        <div class="info-block"><span>Company</span><p>${client.companyName || '-'}</p></div>
        <div class="info-block"><span>Email</span><p>${client.email || '-'}</p></div>
        <div class="info-block"><span>Country</span><p>${client.country || '-'}</p></div>
      `;

      document.getElementById("viewDrawer").classList.add("active");
    });
}

function openImagePreview(src) {
  document.getElementById("previewImg").src = src;
  document.getElementById("imageModal").style.display = "flex";
}

function closeImagePreview() {
  document.getElementById("imageModal").style.display = "none";
}

function closeDrawer() {
  document.getElementById("viewDrawer").classList.remove("active");
}

function editClient(id) {
  window.location.href = `/clients/edit/${id}`;
}

function goToEdit() {
  if (selectedClientId) {
    window.location.href = `/clients/edit/${selectedClientId}`;
  }
}

function openDeleteModal(id) {
  selectedClientId = id;
  document.getElementById("deleteModal").style.display = "flex";
}

function closeDeleteModal() {
  document.getElementById("deleteModal").style.display = "none";
}

function confirmDeleteAction() {
  if (selectedClientId) {
    window.location.href = `/clients/delete/${selectedClientId}`;
  }
}

function confirmDeleteFromDrawer() {
  if (selectedClientId) {
    closeDrawer(); // 👈 optional
    document.getElementById("deleteModal").style.display = "flex";
  }
}
</script>
<script>
  window.addEventListener("load", () => {
    const toast = document.getElementById("toast");

    if (toast) {
      // show for 3 seconds
      setTimeout(() => {
        toast.classList.add("hide");

        // remove from DOM after animation
        setTimeout(() => {
          toast.remove();
        }, 400); // matches CSS animation
      }, 3000);
    }
  });
</script>

</body>
</html>