<!DOCTYPE html>
<html>
<head>
    <title><%= isEdit ? "Edit Work Update" : "Add Work Update" %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
</head>

<body>
<div class="admin-container">

    <%- include('../../partials/sidebar', { activePage: "clients" }) %>

    <div class="main-new">
        <%- include('../../partials/header') %>

        <div class="content-area">

            <!-- BREADCRUMB -->
            <div class="breadcrumb"
                style="font-family:Inter, sans-serif;">
                <a href="/dashboard">Dashboard</a>
                <span> / </span>
                <a href="/clients">Clients</a>
                <span> / </span>
                <a href="/clients/view-page/<%= client._id %>">Client Details</a>
                <span> / </span>
                <span class="active">
                    <%= isEdit ? "Edit Work Update" : "Add Work Update" %>
                </span>
            </div>

            <h2 style="
                margin-bottom:20px;
                font-family:Inter, sans-serif;
                font-weight:600;
            ">
                <%= isEdit ? "Edit Work Update" : "Add Work Update" %>
            </h2>

            <!-- FORM -->
            <form method="POST"
                action="<%= isEdit ? `/clients/workupdate/edit/${work._id}` : `/clients/workupdate/add/${client._id}` %>">

                <div style="
                    background:#fff;
                    padding:20px;
                    border-radius:10px;
                    box-shadow:0 0 10px rgba(0,0,0,0.05);
                    font-family:Inter, sans-serif;
                ">

                    <!-- ROW -->
                    <div style="display:flex; gap:20px; margin-bottom:15px;">

                        <!-- TITLE -->
                        <div style="flex:1;">
                            <label style="font-size:14px; font-weight:500; color:#111;">
                                Title *
                            </label>
                            <input type="text" name="title"
                                value="<%= work ? work.title : '' %>"
                                required
                                style="
                                    width:100%;
                                    padding:10px;
                                    border:1px solid #ddd;
                                    border-radius:6px;
                                    font-size:14px;
                                    font-family:Inter, sans-serif;
                                    outline:none;
                                ">
                        </div>

                        <!-- DATE (FIXED) -->
                        <div style="flex:1;">
                            <label style="font-size:14px; font-weight:500; color:#111;">
                                Work Date *
                            </label>
                            <input type="date" name="date"
                                value="<%= work && work.date ? new Date(work.date).toISOString().split('T')[0] : '' %>"
                                required
                                style="
                                    width:100%;
                                    padding:10px;
                                    border:1px solid #ddd;
                                    border-radius:6px;
                                    font-size:14px;
                                    font-family:Inter, sans-serif;
                                    outline:none;
                                ">
                        </div>

                    </div>

                    <!-- DESCRIPTION -->
                    <div style="margin-bottom:15px;">
                        <label style="font-size:14px; font-weight:500; color:#111;">
                            Description *
                        </label>

                        <textarea name="description" rows="4" required
                            style="
                                width:100%;
                                padding:10px;
                                border:1px solid #ddd;
                                border-radius:6px;
                                font-size:14px;
                                font-family:Inter, sans-serif;
                                outline:none;
                                resize:none;
                            "><%= work ? work.description : '' %></textarea>
                    </div>

                    <!-- STATUS -->
                    <div style="margin-bottom:15px;">
                        <label style="font-size:14px; font-weight:500; color:#111;">
                            Status *
                        </label>

                        <select name="status" required
                            style="
                                width:100%;
                                padding:10px;
                                border:1px solid #ddd;
                                border-radius:6px;
                                font-size:14px;
                                font-family:Inter, sans-serif;
                                outline:none;
                            ">
                            <option value="">Select Status</option>
                            <option value="Pending" <%= work && work.status === "Pending" ? "selected" : "" %>>Pending</option>
                            <option value="In Progress" <%= work && work.status === "In Progress" ? "selected" : "" %>>In Progress</option>
                            <option value="Completed" <%= work && work.status === "Completed" ? "selected" : "" %>>Completed</option>
                        </select>
                    </div>

                    <!-- BUTTONS -->
                    <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px;">

                        <button type="button"
                            onclick="window.location.href='/clients/view-page/<%= client._id %>?tab=workupdate'"
                            style="
                                background:#e5e7eb;
                                color:#374151;
                                border:none;
                                padding:10px 20px;
                                border-radius:6px;
                                cursor:pointer;
                                font-family:Inter, sans-serif;
                                font-size:14px;
                            ">
                            Cancel
                        </button>

                        <button type="submit"
                            style="
                                background:#3b82f6;
                                color:white;
                                border:none;
                                padding:10px 20px;
                                border-radius:6px;
                                cursor:pointer;
                                font-family:Inter, sans-serif;
                                font-size:14px;
                            ">
                            <%= isEdit ? "Update Work" : "Save Work Update" %>
                        </button>

                    </div>

                </div>

            </form>

        </div>
    </div>
</div>

</body>
</html>
