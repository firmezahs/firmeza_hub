<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

  <style>
    .main-new {
      padding: 20px 30px;
      background: #f8fafc;
      min-height: 100vh;
      overflow-y: auto;
      color: #333;
      font-family: 'Inter', sans-serif;
    }

    .hero-banner {
      display: flex;
      background: #1e2b57;
      border-radius: 12px;
      padding: 24px;
      color: white;
      align-items: center;
      gap: 20px;
      margin-bottom: 32px;
    }
    .hero-text h2 { font-size: 28px; margin-bottom: 12px; }
    .hero-text p  { font-size: 16px; opacity: 0.9; line-height: 1.4; margin-bottom: 20px; }
    .hero-text button {
      background: #00f1c1;
      border: none;
      padding: 12px 28px;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      color: #1e2b57;
      font-size: 16px;
      transition: background 0.3s;
    }
    .hero-text button:hover { background: #00dab1; }

    .cards-new {
      display: flex;
      gap: 20px;
      margin-top: 20px;
      margin-bottom: 20px;
    }
    .card-new {
      background: white;
      padding: 20px 25px;
      border-radius: 12px;
      box-shadow: 0 0 15px rgba(0,0,0,0.05);
      flex: 1;
      font-weight: 600;
      font-size: 16px;
      color: #222;
      text-align: center;
    }
    .card-new p {
      font-size: 28px;
      margin-top: 10px;
      font-weight: 700;
      color: #1e2b57;
    }

    /* Developer welcome card */
    .dev-welcome {
      background: white;
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 0 15px rgba(0,0,0,0.05);
      margin-top: 20px;
    }
    .dev-welcome h3 { margin: 0 0 8px; color: #1e2b57; }
    .dev-welcome p  { color: #666; font-size: 14px; margin: 0; }
  </style>
</head>
<body>

<div class="admin-container">

  <!-- SIDEBAR: role-aware -->
  <div class="sidebar-new">
    <h2>Firmeza</h2>

    <a class="active" href="/dashboard"><i class="ri-home-4-fill"></i> Dashboard</a>
    <a href="/clients"><i class="ri-user-fill"></i> Clients</a>

    <!-- Admin-only sidebar links -->
    <% if (user && user.role === 'admin') { %>
      <a href="/developers"><i class="ri-team-line"></i> Developers</a>
      <a href="/services"><i class="ri-customer-service-2-line"></i> Services</a>
    <% } %>

    <a href="/auth/logout"><i class="ri-logout-box-r-line"></i> Logout</a>
  </div>

  <!-- MAIN -->
  <div class="main-new">

    <%- include('partials/header') %>

    <!-- Hero Banner — shown to all -->
    <div class="hero-banner">
      <div class="hero-text">
        <h2>Enter the new era of firmeza-hub!</h2>
        <button>Let's Start!</button>
      </div>
    </div>

    <!-- Admin: show Clients + Pending cards -->
    <% if (user && user.role === 'admin') { %>
      <div class="cards-new">
        <div class="card-new">
          Clients
          <p><%= clientCount || 0 %></p>
        </div>
        <div class="card-new">
          Pending
          <p><%= pendingCount || 0 %></p>
        </div>
      </div>
    <% } %>

    <!-- Developer: show a personalised welcome instead -->
    <% if (user && user.role === 'developer') { %>
      <div class="dev-welcome">
        <h3>Welcome, <%= user.name %>!</h3>
        <p>You can view your assigned clients and their project details from the Clients section.</p>
      </div>
    <% } %>

  </div>

</div>

</body>
</html>
