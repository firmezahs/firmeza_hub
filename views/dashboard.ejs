
<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">

  <!-- Icons -->
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

  <style>
    /* Minimal styling to mimic the screenshot layout */

    .main-new {
      padding: 20px 30px;
      background: #f8fafc;
      min-height: 100vh;
      overflow-y: auto;
      color: #333;
      font-family: 'Inter', sans-serif;
    }

    .hero-banner {
      display: flex;
      background: #1e2b57;
      border-radius: 12px;
      padding: 24px;
      color: white;
      align-items: center;
      gap: 20px;
      margin-bottom: 32px;
    }
    .hero-banner img {
      width: 200px;
      border-radius: 8px;
      box-shadow: 0 0 15px rgba(0,0,0,0.2);
    }
    .hero-text {
      max-width: 600px;
    }
    .hero-text h2 {
      font-size: 28px;
      margin-bottom: 12px;
    }
    .hero-text p {
      font-size: 16px;
      opacity: 0.9;
      line-height: 1.4;
      margin-bottom: 20px;
    }
    .hero-text button {
      background: #00f1c1;
      border: none;
      padding: 12px 28px;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      color: #1e2b57;
      font-size: 16px;
      transition: background 0.3s;
    }
    .hero-text button:hover {
      background: #00dab1;
    }


    /* Placeholder chart area */
    .chart-placeholder {
      height: 220px;
      background: #f0f4ff;
      border-radius: 8px;
      position: relative;
    }

    .legend {
      display: flex;
      justify-content: flex-end;
      gap: 15px;
      margin-top: 10px;
      font-size: 13px;
      color: #666;
    }

    .legend span {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .legend .blue-dot, .legend .cyan-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
    }
    .legend .blue-dot {
      background: #3b4cca;
    }
    .legend .cyan-dot {
      background: #27c6f5;
    }

    /* Cards container */
    .cards-new {
      display: flex;
      gap: 20px;
      margin-top: 20px;
      margin-bottom: 20px;
    }
    .card-new {
      background: white;
      padding: 20px 25px;
      border-radius: 12px;
      box-shadow: 0 0 15px rgba(0,0,0,0.05);
      flex: 1;
      font-weight: 600;
      font-size: 16px;
      color: #222;
      text-align: center;
    }
    .card-new p {
      font-size: 28px;
      margin-top: 10px;
      font-weight: 700;
      color: #1e2b57;
    }
  </style>
</head>
<body>

<div class="admin-container">

  <!-- SIDEBAR -->
  <div class="sidebar-new">
    <h2>Firmeza</h2>

    <a class="active" href="/dashboard"><i class="ri-home-4-fill"></i> Dashboard</a>
    <a href="/clients"><i class="ri-user-fill"></i> Clients</a>
    <a href="/developers"><i class="ri-user-fill"></i> Developers</a>
    <a><i class="ri-file-list-3-line"></i> Agreements</a>
    <a><i class="ri-box-3-line"></i> Products</a>
    <a href="/auth/logout"><i class="ri-logout-box-r-line"></i> Logout</a>
  </div>

  <!-- MAIN -->
  <div class="main-new">

    <%- include('partials/header') %>

    <!-- Hero Banner -->
    <div class="hero-banner">
      <!-- <img src="https://cdn.adminjs.co/assets/ai-banner.png" alt="AI Generate Banner"> -->
      <div class="hero-text">
        <h2>Enter the new era of firmeza-hub!</h2>
        <!-- <p>Our system leverages AI to effortlessly generate text and images. Simplify your product database management with just one click.</p> -->
        <button>Let's Start!</button>
      </div>
    </div>

    <!-- Cards -->
    <div class="cards-new">
      <div class="card-new">
        Total Agreements
        <p>12</p>
      </div>
      <div class="card-new">
        Clients
        <p>5</p>
      </div>
      <div class="card-new">
        Pending
        <p>3</p>
      </div>
    </div>

  </div>

</div>

</body>
</html>