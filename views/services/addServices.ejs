<!DOCTYPE html>
<html>
<head>
  <title><%= service ? "Edit Service" : "Add Service" %></title>
  <link rel="stylesheet" href="/css/style.css">

  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
</head>

<body>

<div class="admin-container">

  <!-- SIDEBAR -->
  <div class="sidebar-new">
    <h2>Firmeza</h2>

    <a href="/dashboard"><i class="ri-home-4-fill"></i> Dashboard</a>
    <a href="/clients"><i class="ri-user-fill"></i> Clients</a>
    <a href="/developers"><i class="ri-user-fill"></i> Developers</a>

    <a class="active" href="/services">
      <i class="ri-customer-service-2-line"></i> Services
    </a>

    <a><i class="ri-file-list-3-line"></i> Agreements</a>
    <a><i class="ri-box-3-line"></i> Products</a>
    <a href="/auth/logout"><i class="ri-logout-box-r-line"></i> Logout</a>
  </div>

  <!-- MAIN -->
  <div class="main-new">

    <%- include('../partials/header') %>

    <div class="content-area">

      <!-- BREADCRUMB -->
      <div class="breadcrumb">
        <a href="/dashboard">Dashboard</a> /
        <a href="/services">Services</a> /
        <span class="crumb-current">
          <%= service ? "Edit Service" : "Add Service" %>
        </span>
      </div>

      <!-- TITLE -->
      <div class="page-header-new">
        <h1><%= service ? "Edit Service" : "Add Service" %></h1>
      </div>

      <!-- FORM CARD -->
      <div class="form-card">

        <form 
          id="serviceForm"
          action="<%= service ? '/services/update/' + service._id : '/services/add' %>" 
          method="POST" 
          class="client-form"
        >

          <!-- NAME -->
          <div class="form-group" style="grid-column: span 2;">
            <label>Name <span class="required">*</span></label>
            <input 
              type="text" 
              name="name" 
              placeholder="Enter Service Name" 
              required
              value="<%= service ? service.name : '' %>"
            >
          </div>

          <!-- ACTIONS -->
          <div class="form-actions">
            <a href="/services" class="cancel-btn">Cancel</a>

            <button type="submit" class="save-btn">
              <%= service ? "Update Service" : "Save Service" %>
            </button>
          </div>

        </form>

      </div>

    </div>

  </div>

</div>

<!-- ✅ SAVE / UPDATE CONFIRM MODAL -->
<div id="saveModal" class="confirm-modal" style="display:none;">
  <div class="confirm-box" id="confirmBox">

    <div class="confirm-header">
      <h2 id="confirmTitle">Confirm</h2>
      <span class="close-btn" onclick="closeSave()">×</span>
    </div>

    <p class="confirm-text" id="confirmText">
      Do you really want to save this service?
    </p>

    <div class="confirm-actions">
      <button class="cancel-btn" onclick="closeSave()">Cancel</button>
      <button class="confirm-btn" id="confirmBtn" onclick="confirmSave()">Confirm</button>
    </div>

  </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script>
  let formToSubmit = null;

  // detect mode from EJS (BEST way)
  const isEdit = "<%= service ? 'true' : 'false' %>" === "true";

  // INTERCEPT FORM SUBMIT
  $('#serviceForm').on('submit', function(e) {
    e.preventDefault();
    formToSubmit = this;

    if (isEdit) {
      // UPDATE MODE (orange)
      $('#confirmText').text('Do you really want to update this service?');
      $('#confirmBox').css('border-left', '6px solid #f59e0b');
      $('#confirmTitle').css('color', '#f59e0b');
      $('#confirmBtn').css('background', '#f59e0b');
    } else {
      // SAVE MODE (blue)
      $('#confirmText').text('Do you really want to save this service?');
      $('#confirmBox').css('border-left', '6px solid #3b82f6');
      $('#confirmTitle').css('color', '#3b82f6');
      $('#confirmBtn').css('background', '#3b82f6');
    }

    $('#saveModal').css('display', 'flex');
  });

  function closeSave() {
    formToSubmit = null;
    $('#saveModal').hide();
  }

  function confirmSave() {
    if (formToSubmit) {
      formToSubmit.submit();
    }
  }
</script>

</body>
</html>