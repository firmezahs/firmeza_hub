<!DOCTYPE html>
<html>

<head>
  <title>Services | Firmeza Hub</title>

  <link rel="stylesheet" href="/css/style.css">

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
</head>

<body>

  <div class="admin-container">

    <%- include('../partials/sidebar', { activePage: 'services' }) %>

      <div class="main-new">
        <%- include('../partials/header') %>

          <div class="content-area">

            <p class="breadcrumb">
              <a href="/dashboard">Dashboard</a> /
              <a href="/services" class="active">Services</a>
            </p>

            <div class="page-header-new">
              <h1>Services <span class="badge">
                  <%= services?.length || 0 %>
                </span></h1>
            </div>

            <!-- SEARCH -->
            <div class="filter-bar">
              <div class="search-box">
                <i class="ri-search-line"></i>
                <input type="text" id="customSearch" placeholder="Search..." />
              </div>

              <!-- ✅ SAME STRUCTURE AS CLIENTS -->
              <div class="right-controls">
                <button class="add-btn" onclick="window.location.href='/services/add'">
                  <i class="ri-add-line"></i> Add Service
                </button>

                <select id="entriesDropdown" class="entries-dropdown">
                  <option value="10">10</option>
                  <option value="25">25</option>
                  <option value="50">50</option>
                </select>
              </div>
            </div>

            <!-- TABLE -->
            <div class="table-wrapper">
              <table id="servicesTable" class="custom-table">

                <thead>
                  <tr>
                    <th><input type="checkbox" id="selectAll"></th>
                    <th>Service</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th></th>
                  </tr>
                </thead>

                <tbody>
                  <% services.forEach(service=> { %>
                    <tr>

                      <td><input type="checkbox" class="rowCheckbox"></td>

                      <td>
                        <div class="client-main">
                          <div class="client-info">
                            <p class="client-code">#<%= service.serviceId %></p>
                            <p class="client-name action-click" data-id="<%= service._id %>" data-action="view">
                              <%= service.name %>
                            </p>
                          </div>
                        </div>
                      </td>

                      <td>
                        <%= new Date(service.createdAt).toLocaleDateString() %>
                      </td>
                      <td>
                        <%= new Date(service.updatedAt).toLocaleDateString() %>
                      </td>

                      <!-- ✅ YOUR ORIGINAL 3-DOTS MENU (UNCHANGED) -->
                      <td class="actions">
                        <div class="action-menu">
                          <i class="ri-more-2-fill menu-toggle"></i>

                          <div class="dropdown">
                            <div class="dropdown-item action-click" data-action="view" data-id="<%= service._id %>">
                              <i class="ri-eye-line"></i> View
                            </div>

                            <div class="dropdown-item action-click" data-action="edit" data-id="<%= service._id %>">
                              <i class="ri-edit-line"></i> Edit
                            </div>

                            <div class="dropdown-item action-click delete-text" data-action="delete"
                              data-id="<%= service._id %>">
                              <i class="ri-delete-bin-6-line"></i> Delete
                            </div>
                          </div>
                        </div>
                      </td>

                    </tr>
                    <% }) %>
                </tbody>

              </table>
            </div>

          </div>
      </div>
  </div>

  <!-- DELETE MODAL -->
  <div id="deleteModal" class="modal">
    <div class="modal-content modern">
      <h3>Confirm Delete</h3>
      <p>Do you really want to delete?</p>

      <div class="modal-actions">
        <button onclick="closeDelete()">Cancel</button>
        <button onclick="confirmDelete()" class="delete-btn">Delete</button>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

  <script>

    let deleteId = null;

    // SEARCH
    $('#customSearch').on('keyup', function () {
      let val = $(this).val().toLowerCase();
      $('#servicesTable tbody tr').filter(function () {
        $(this).toggle($(this).text().toLowerCase().indexOf(val) > -1);
      });
    });

    // ✅ KEEP YOUR MENU TOGGLE WORKING
    $(document).on('click', '.menu-toggle', function (e) {
      e.stopPropagation();
      $('.dropdown').hide();
      $(this).siblings('.dropdown').toggle();
    });

    $(document).on('click', function () {
      $('.dropdown').hide();
    });

    // ACTION HANDLER
    $(document).on('click', '.action-click', function (e) {
      e.stopPropagation();

      const id = $(this).data('id');
      const action = $(this).data('action');

      if (!id || !action) return;

      if (action === 'view') {
        window.location.href = "/services/view/" + id;
      }

      if (action === 'edit') {
        window.location.href = "/services/edit/" + id;
      }

      if (action === 'delete') {
        deleteId = id;
        $('#deleteModal').css('display', 'flex');
      }
    });

    // DELETE
    function closeDelete() {
      $('#deleteModal').hide();
    }

    function confirmDelete() {
      if (deleteId) {
        window.location.href = "/services/delete/" + deleteId;
      }
    }

  </script>

</body>

</html>